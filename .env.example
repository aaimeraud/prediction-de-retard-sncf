# SNCF Delay Prediction - Environment Configuration
# Copy this file to .env.prod and fill in actual values
# NEVER commit .env files to version control

# TensorFlow Configuration
TF_CPP_MIN_LOG_LEVEL=2
PYTHONUNBUFFERED=1

# API Configuration
HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4

# Model Configuration
MODEL_PATH=./models/delay_classifier.keras
MODEL_VERSION=v1.0

# Development vs Production
ENVIRONMENT=production

# Optional: Database Configuration (for future features)
# DATABASE_URL=postgresql://user:password@postgres:5432/sncf_delays
# DATABASE_MIN_POOL_SIZE=1
# DATABASE_MAX_POOL_SIZE=10

# Optional: Authentication (for future API key security)
# API_KEY=your-secret-api-key-here
# API_SECRET=your-secret-key-here

# Logging Configuration
LOG_LEVEL=info
LOG_FORMAT=json

# Optional: Monitoring/Observability
# PROMETHEUS_PORT=9090
# JAEGER_ENABLED=false